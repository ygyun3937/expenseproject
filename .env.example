GEMINI_API_KEY=your-api-key-here

# 관리자 설정 모달 비밀번호 (⚙️ 설정 버튼에서 한도 변경 시 필요). 미설정 시 기본값 "admin".
ADMIN_PASSWORD=admin

# 회사 규정: 1인당 식대 한도 (원). 초과 시 표에 빨간색 경고 표시 + 한도까지만 정산.
MEAL_LIMIT_PER_PERSON=12000

# 회사 규정: 1인 1박 숙박비 한도 (원). 초과 시 표에 빨간색 경고 표시 + 한도까지만 정산.
LODGING_LIMIT_PER_NIGHT=70000

# 해외 출장 한도 (원화 환산 기준). 0 이면 미적용.
OVERSEAS_MEAL_LIMIT_PER_PERSON=0
OVERSEAS_LODGING_LIMIT_PER_NIGHT=0

# 유가 (원/L) — 관리자 설정 ⚙️ 모달에서도 변경 가능. 0 이면 미적용.
FUEL_PRICE_GASOLINE=0
FUEL_PRICE_DIESEL=0
FUEL_PRICE_LPG=0
